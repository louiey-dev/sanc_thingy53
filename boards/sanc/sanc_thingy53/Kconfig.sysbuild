if BOARD_SANC_THINGY53_NRF5340_CPUAPP || BOARD_SANC_THINGY53_NRF5340_CPUAPP_NS

choice BOOTLOADER
	default BOOTLOADER_MCUBOOT
endchoice

choice MCUBOOT_MODE
	default MCUBOOT_MODE_OVERWRITE_ONLY
endchoice

config SECURE_BOOT_NETCORE
	default y

config NETCORE_APP_UPDATE
	default y if SECURE_BOOT_NETCORE

config MCUBOOT_USE_ALL_AVAILABLE_RAM
	default y if BOARD_SANC_THINGY53_NRF5340_CPUAPP_NS && BOOTLOADER_MCUBOOT

endif # BOARD_SANC_THINGY53_NRF5340_CPUAPP || BOARD_SANC_THINGY53_NRF5340_CPUAPP_NS

config PM_EXTERNAL_FLASH_MCUBOOT_SECONDARY
	default y if BOOTLOADER_MCUBOOT

config PARTITION_MANAGER
	default y
